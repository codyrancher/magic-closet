# Copy to .env and adjust. Every value here is optional — sensible defaults
# are baked into the compose files.

# Which sidecars start with `docker compose up -d`. Comma-separated list of
# profile names (= sidecar directory names). Remove one to make `up` skip it;
# it can still be started later via the API or `mc start <name>`.
COMPOSE_PROFILES=vscode,rancher-browser,rancher,keycloak

# ---- Port forwarding -------------------------------------------------------
# One host port per service. Change the value, `docker compose up -d`, done.
API_PORT=8300          # sidecar control API
VSCODE_PORT=8310       # VS Code in the browser
RANCHER_BROWSER_PORT=8320      # Chromium web UI
RANCHER_PORT=8444      # Rancher server (https)
KEYCLOAK_PORT=8330     # Keycloak OIDC provider
OPENLDAP_PORT=8340     # OpenLDAP (ldap)
SAMBA_LDAP_PORT=8350   # Samba AD (ldap)
FIGMA_PORT=8360        # Figma MCP server
DEV_PORT=8305          # dev server running inside the project container (container port 8005)

# ---- User mapping ----------------------------------------------------------
PUID=1000
PGID=1000

# ---- Sidecar parameters ----------------------------------------------------
# Also settable per-start through the API: POST /sidecars/<name>/start
RANCHER_TAG=head
FIGMA_API_KEY=
RANCHER_AUTH_PROVIDER=keycloak
# NODE_VERSION is auto-filled by the api from rancher/dashboard:master
NODE_VERSION=
GH_TOKEN=
APPCO_EMAIL=
APPCO_TOKEN=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_DEFAULT_REGION=us-west-2

# ---- Generated secrets -----------------------------------------------------
# Leave empty — filled automatically by setup.sh (or by the api on boot).
RANCHER_BOOTSTRAP_PASSWORD=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=
OPENLDAP_ADMIN_PASSWORD=
FREEIPA_ADMIN_PASSWORD=
RANCHER_PRIME=
GITHUB_URL=
SAMBA_ADMIN_PASSWORD=
