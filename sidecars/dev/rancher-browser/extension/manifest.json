{
  "manifest_version": 3,
  "name": "Rancher Auto Login",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": [
        "https://localhost/*",
        "https://rancher/*",
        "http://keycloak/*",
        "http://*/realms/*",
        "https://*/realms/*"
      ],
      "js": [
        "config.js",
        "autofill.js",
        "command-menu.js"
      ],
      "css": [
        "styles.css",
        "command-menu.css"
      ],
      "run_at": "document_idle"
    }
  ]
}